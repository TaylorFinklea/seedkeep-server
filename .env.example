# Seedkeep server — environment variables.
# Copy to .env for local dev. Every variable here is required unless noted.

# ─── Server ────────────────────────────────────────────────────────────────
PORT=8787
APP_ENV=development                      # development | staging | production

# ─── Database (PostgreSQL) ─────────────────────────────────────────────────
# Local docker-compose default. Override for managed Postgres on Fly/Render/etc.
DATABASE_URL=postgres://seedkeep:dev-only@localhost:5432/seedkeep

# ─── Object storage (S3-compatible) ────────────────────────────────────────
# Local docker-compose uses MinIO. For Cloudflare R2, set:
#   S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
#   S3_REGION=auto
# For AWS S3, leave S3_ENDPOINT empty and set the AWS_ region.
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minio
S3_SECRET_ACCESS_KEY=dev-only-secret
S3_BUCKET=seedkeep-photos
S3_FORCE_PATH_STYLE=true                 # required for MinIO; AWS S3 / R2 use virtual-host

# ─── Auth (better-auth) ────────────────────────────────────────────────────
# Generate with `openssl rand -hex 32`
BETTER_AUTH_SECRET=replace-me-with-32-random-bytes

# ─── Sign in with Apple ────────────────────────────────────────────────────
# Native App ID (from Apple Developer portal). The iOS bundle identifier.
APPLE_CLIENT_ID=com.example.seedkeep
# JWT-signed client secret. See better-auth docs for generation.
APPLE_CLIENT_SECRET=replace-with-jwt

# ─── AI providers ──────────────────────────────────────────────────────────
# Server-side key, used only when the user is on the "hosted" tier. Optional
# for the dev workflow (extraction route returns 503 when this is blank).
ANTHROPIC_API_KEY=

# ─── Model selection ───────────────────────────────────────────────────────
DEFAULT_VISION_MODEL=claude-sonnet-4-6
DEFAULT_REVIEW_MODEL=claude-haiku-4-5-20251001
